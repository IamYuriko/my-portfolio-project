---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Cursor from "../components/Cursor.astro";
import Loading from "../components/Loading.astro";
import "../styles/style.css";

const { title = "Narita Yuriko" } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="title" content="Narita Yuriko" />
    <meta name="description" content="Narita Yuriko's Portfolio" />
    <link rel="icon" href="/icons/favicon.ico" type="image/png" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="" />
    <meta property="og:site_name" content="Narita Yuriko" />
    <meta property="og:title" content="Narita Yuriko" />
    <meta property="og:description" content="Narita Yuriko's Portfolio" />
    <meta property="og:image" content="../assets/heyimyuriko.com_.png" />
    <meta property="og:image:alt" content="Narita Yuriko's Portfolio" />
  </head>
  <body>
    <Loading />
    <Cursor />
    <Header />
    <slot />
    <Footer />
  </body>
  <script src="../scripts/script.js"></script>
</html>
